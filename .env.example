NODE_ENV=development
PORT=3001
# Comma-separated. Production: CORS_ORIGIN=https://zupiq.ai,https://www.zupiq.ai
CORS_ORIGIN=http://localhost:5173,http://localhost:5180

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Auth
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# File uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Firebase Admin (service account values)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Stripe Billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRODUCT_CORE=prod_your_core_product_id
STRIPE_PRICE_CORE_MONTHLY=price_your_core_monthly_price_id
STRIPE_PRICE_CORE_ANNUAL=
STRIPE_PRODUCT_PRO=prod_your_pro_product_id
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_price_id
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_CHECKOUT_SUCCESS_URL=https://zupiq.ai/plan?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=https://zupiq.ai/plan?checkout=cancel
STRIPE_BILLING_PORTAL_RETURN_URL=https://zupiq.ai/plan
